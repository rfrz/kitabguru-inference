# App
APP_NAME=KitabGuru Inference Engine
API_PREFIX=/api
CORS_ORIGINS=*
DATABASE_URL=sqlite:///./data/app.db
QDRANT_LOCATION=./data/qdrant
# QDRANT_LOCATION=http://localhost:6333
# QDRANT_API_KEY=your_qdrant_api_key_if_needed
QDRANT_COLLECTION=epub_collection
RETRIEVAL_CANDIDATE_K=30
RETRIEVAL_FINAL_K=12
RETRIEVAL_NEIGHBOR_WINDOW=1
RAG_ENABLE_COMPLETENESS_SCAN=true
RAG_MAX_EVAL_RETRIES=3
EVALUATOR_LLM_MODEL=gemini-1.5-flash
CHUNK_SIZE=1200
CHUNK_OVERLAP=160

# Embedding Config
EMBEDDING_PROVIDER=huggingface
EMBEDDING_DIMENSION=
HF_API_KEY=your_hf_token
HF_EMBEDDING_MODEL=intfloat/multilingual-e5-large
GEMINI_API_KEY=your_gemini_key
GEMINI_EMBEDDING_MODEL=text-embedding-004

# LLM Config & Fallback Priority
LLM_FALLBACK_ORDER=gemini,groq,openrouter,openai_compatible
LLM_TEMPERATURE=0

GEMINI_LLM_MODEL=gemini-1.5-flash
GROQ_API_KEY=your_groq_key
GROQ_LLM_MODEL=llama3-70b-8192
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_LLM_MODEL=meta-llama/llama-3-70b-instruct
OPENAI_COMPATIBLE_API_KEY=your_custom_key
OPENAI_COMPATIBLE_BASE_URL=https://api.your-custom-provider.com/v1
OPENAI_COMPATIBLE_MODEL=custom-model-name
